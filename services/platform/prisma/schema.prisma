generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  moduleFormat       = "esm"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
  schemas  = ["platform"]
}

model PlatformTenantViewRecord {
  id             String   @id @db.Uuid
  tenantId       String?  @map("tenant_id") @db.Uuid
  status         String
  version        Int      @default(1)
  idempotencyKey String?  @unique @map("idempotency_key")
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@schema("platform")
  @@map("platform_tenant_views")
}

model OutboxEvent {
  id            String   @id @db.Uuid
  aggregateId   String   @map("aggregate_id") @db.Uuid
  tenantId      String?  @map("tenant_id") @db.Uuid
  eventType     String   @map("event_type")
  payload       Json
  occurredAt    DateTime @default(now()) @map("occurred_at")
  processedAt   DateTime? @map("processed_at")

  retryCount    Int       @default(0) @map("retry_count")
  lastError     String?   @map("last_error")
  lastErrorAt   DateTime? @map("last_error_at")

  @@index([tenantId])
  @@index([processedAt])
  @@index([retryCount])
  @@schema("platform")
  @@map("platform_tenant_views_outbox")
}

model EventBusEventRecord {
  id          String   @id @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  source      String
  eventType   String   @map("event_type")
  aggregateId String?  @map("aggregate_id") @db.Uuid
  payload     Json
  receivedAt  DateTime @default(now()) @map("received_at")

  @@index([tenantId])
  @@index([source, eventType])
  @@index([receivedAt])
  @@schema("platform")
  @@map("event_bus_events")
}

model BillingProviderSessionRecord {
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  planId    String?  @map("plan_id") @db.Uuid
  kind      String
  status    String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([kind, status])
  @@schema("platform")
  @@map("billing_provider_sessions")
}
