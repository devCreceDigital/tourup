# ──────────────────────────────────────────────────────────────────────────────
# Tourup — Variables de entorno
# Copia este archivo a .env y ajusta los valores.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=totem_hub
POSTGRES_USER=totem
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_PORT=5432

# ── Seguridad ─────────────────────────────────────────────────────────────────
SERVICE_INTERNAL_SECRET=change-me-internal-secret-minimum-32-chars
APP_JWT_SECRET=change-me-jwt-secret-minimum-32-characters
APP_JWT_ISSUER=totem-hub

# ── Entorno ───────────────────────────────────────────────────────────────────
APP_ENV=local                          # local | production
APP_URL=http://localhost:3001          # URL pública de la app (para links en emails)

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxx
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
NOTIFICATIONS_SERVICE_URL=http://localhost:4111  # URL interna del servicio de notificaciones

# ── Verificación de email ─────────────────────────────────────────────────────
REQUIRE_EMAIL_VERIFICATION=false       # true en producción

# ── Rate limiting Redis (opcional — sin esto usa in-memory) ──────────────────
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Límites de rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_ANONYMOUS_RPM=60
RATE_LIMIT_USER_RPM=300
RATE_LIMIT_USER_RPH=3000

# ── Outbox ────────────────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_MAX_RETRIES=5

# ── Asistente IA ──────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-xxxx
ASSISTANT_MODEL=gemma3:4b
ASSISTANT_DEFAULT_TENANT_ID=           # UUID del tenant por defecto para el asistente público
