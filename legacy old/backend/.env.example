# ============================================================
# TOTEM BACKEND — Variables de entorno
# Copiar este archivo a .env y rellenar los valores reales
# ============================================================

# Django
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Supabase JWT Secret
# Encuéntralo en: supabase.com → tu proyecto → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Base de datos Supabase (PostgreSQL)
# Encuéntrala en: supabase.com → tu proyecto → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Supabase API Keys
# Encuéntralos en: supabase.com → tu proyecto → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key


OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=TOTEMHUB
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
